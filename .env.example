# =====================================================================
# DAP - Variables de entorno
# =====================================================================
# Copiar a `.env.local` y rellenar con valores reales (NO commitear).
# Las variables NEXT_PUBLIC_* se exponen al cliente; el resto SOLO server.
# Mantener en sync con CLAUDE.md §7.
# =====================================================================

# --- Supabase ---------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CRÍTICO: el service role bypasea RLS. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe -----------------------------------------------------------
# Modo test al desarrollar; cambia al live key en producción.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Mux --------------------------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# --- Resend (email transaccional) -------------------------------------
RESEND_API_KEY=
EMAIL_FROM=DAP <hola@dap.tudominio>

# --- App --------------------------------------------------------------
# En Vercel: usar la URL del deploy (https://dap.tudominio o el preview).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Anthropic / Claude (Fase 5: tutor IA) ----------------------------
ANTHROPIC_API_KEY=
